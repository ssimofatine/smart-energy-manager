<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smartenergy.controller.LecturaController"
            styleClass="view-box">

    <top>
        <VBox spacing="12">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Lecturas" styleClass="view-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="+ Nueva lectura" onAction="#onNuevaLectura" styleClass="accent-button"/>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Dispositivo" styleClass="view-subtitle"/>
                <ComboBox fx:id="dispositivoFilterCombo" prefWidth="220"/>
                <Label text="Desde" styleClass="view-subtitle"/>
                <DatePicker fx:id="desdeDatePicker"/>
                <Label text="Hasta" styleClass="view-subtitle"/>
                <DatePicker fx:id="hastaDatePicker"/>
                <Button text="Filtrar" onAction="#onFiltrar" styleClass="nav-button"/>
                <Button text="Limpiar" onAction="#onLimpiarFiltros" styleClass="nav-button"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TableView fx:id="lecturasTable" styleClass="devices-table">
            <columns>
                <TableColumn fx:id="fechaHoraColumn" text="Fecha/Hora" prefWidth="220"/>
                <TableColumn fx:id="dispositivoColumn" text="Dispositivo" prefWidth="240"/>
                <TableColumn fx:id="consumoColumn" text="kWh" prefWidth="120"/>
                <TableColumn fx:id="costeColumn" text="Coste (€)" prefWidth="140"/>
            </columns>
        </TableView>
    </center>

    <bottom>
        <HBox spacing="20" alignment="CENTER_LEFT" styleClass="detail-panel">
            <padding>
                <Insets top="12" right="14" bottom="12" left="14"/>
            </padding>
            <Label fx:id="totalKwhLabel" text="Total kWh: 0.000" styleClass="detail-title"/>
            <Label fx:id="totalCosteLabel" text="Total coste: 0.00 EUR" styleClass="detail-title"/>
        </HBox>
    </bottom>
</BorderPane>
