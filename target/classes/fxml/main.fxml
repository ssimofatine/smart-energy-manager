<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smartenergy.controller.MainController"
            styleClass="app-root">

    <left>
        <VBox spacing="12" prefWidth="220" styleClass="sidebar">
            <padding>
                <Insets top="24" right="16" bottom="24" left="16"/>
            </padding>
            <Label text="Smart Energy" styleClass="sidebar-title"/>
            <Button text="Panel" onAction="#showPanel" maxWidth="Infinity" styleClass="nav-button"/>
            <Button text="Dispositivos" onAction="#showDispositivos" maxWidth="Infinity" styleClass="nav-button"/>
            <Button text="Lecturas" onAction="#showLecturas" maxWidth="Infinity" styleClass="nav-button"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentPane" styleClass="content-pane"/>
    </center>

</BorderPane>
